FROM apache/kafka:latest

EXPOSE 9092
EXPOSE 9094

ENV KAFKA_NODE_ID=0
ENV KAFKA_PROCESS_ROLES=broker,controller

ENV KAFKA_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093,EXTERNAL://:9094
ENV KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,EXTERNAL://localhost:9094

ENV KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,EXTERNAL:PLAINTEXT,PLAINTEXT:PLAINTEXT
ENV KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
ENV KAFKA_CONTROLLER_QUORUM_VOTERS=0@kafka:9093