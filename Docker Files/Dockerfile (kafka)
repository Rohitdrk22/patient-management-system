FROM apache/kafka:latest

EXPOSE 9092

# Unique node id (must match quorum voters)
ENV KAFKA_NODE_ID=1

# Run both broker + controller (KRaft mode)
ENV KAFKA_PROCESS_ROLES=broker,controller

# Define listeners (bind to all interfaces)
ENV KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093

# What clients will use to connect
ENV KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092

# Map protocols
ENV KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT

# Controller listener name (must exist in LISTENERS)
ENV KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER

# Quorum voters (nodeId@host:port)
ENV KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093

# Required for storage in KRaft
ENV KAFKA_LOG_DIRS=/tmp/kraft-combined-logs

# Required cluster id
ENV KAFKA_CLUSTER_ID=kraft-cluster-1